# Database Configuration
# Use MongoDB Atlas by replacing the URL below with your cluster connection string.
# Example:
# MONGO_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/energy-monitoring?retryWrites=true&w=majority
# Or use a local MongoDB instance if needed:
MONGO_URL=mongodb://localhost:27017/energy-monitoring

# Server Configuration
PORT=7000
NODE_ENV=development

# JWT Configuration (for future use)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Email Configuration (for alerts and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# SMS Configuration (for alerts)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_FROM_NUMBER=+1234567890

# Cost Configuration
COST_PER_KWH=0.12

# Application Settings
APP_NAME=Smart Energy Consumption Monitoring System
APP_VERSION=1.0.0
APP_TIMEZONE=UTC
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# API Keys (if using external services)
WEATHER_API_KEY=your_weather_api_key
ANALYTICS_API_KEY=your_analytics_api_key
